{
  "name": "agstell-cli",
  "version": "0.2.0",
  "description": "CLI for AgentMarket — discover and call APIs with x402 micropayments on Stellar",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "bin/"
  ],
  "bin": {
    "agentmarket": "bin/agentmarket.js",
    "am": "bin/agentmarket.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs --dts --clean",
    "dev": "tsup src/cli.ts --format cjs --watch",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "keywords": [
    "cli",
    "agentmarket",
    "stellar",
    "x402",
    "ai-agents",
    "api"
  ],
  "author": "AgentMarket",
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^13.1.0",
    "agstell-sdk": "^0.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.0.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
